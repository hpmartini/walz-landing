---
import services from '../data/services.json';

const icons: Record<string, string> = {
  rocket: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.5 14.5L10 21l3-3 5-1 3-5-8.5-8.5-5 3-1 5-3 3 6 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.5 14.5l5-5"/></svg>`,
  target: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 12m-9 0a9 9 0 1018 0 9 9 0 10-18 0"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 12m-5 0a5 5 0 1010 0 5 5 0 10-10 0"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 12m-1 0a1 1 0 102 0 1 1 0 10-2 0"/></svg>`,
  chart: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 19V5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 19h16"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 15l3-3 3 2 4-6"/></svg>`,
  calculator: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 3h10a2 2 0 012 2v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h8"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 11h.01M12 11h.01M16 11h.01M8 15h.01M12 15h.01M16 15h.01"/></svg>`,
  document: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3h6l4 4v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 11h6M9 15h6"/></svg>`,
  users: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 20H2v-2a3 3 0 015.356-1.857"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 20v-2a5 5 0 0110 0v2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  shield: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V7l8-4z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4"/></svg>`,
  file: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3h6l4 4v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6"/></svg>`,
};
---

<section class="py-20 md:py-24 bg-bg-alt">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
        Unsere Leistungen
      </h2>
      <div class="w-16 h-1 bg-secondary mx-auto"></div>
      <p class="text-text-light max-w-2xl mx-auto mt-5">
        Von der Existenzgründung bis zur laufenden Betreuung: Wir schaffen Klarheit, Sicherheit und entlasten Sie im Alltag.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service, idx) => (
        <a
          href={`/leistungen/${service.slug}`}
          class="group reveal bg-white p-8 rounded-xl shadow-sm border border-secondary/15 hover:border-secondary/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
          style={`transition-delay:${Math.min(idx * 60, 240)}ms`}
        >
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-secondary/10 text-secondary border border-secondary/20 mb-5 transition-all duration-300 group-hover:bg-secondary/15 group-hover:scale-105" set:html={icons[service.icon] ?? icons.file} />
          <h3 class="text-xl font-semibold text-primary mb-3">
            {service.title}
          </h3>
          <p class="text-text-light mb-5">
            {service.shortDesc}
          </p>
          <span class="text-primary font-medium group-hover:text-primary-light transition-colors duration-300 inline-flex items-center gap-1">
            Mehr erfahren
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
