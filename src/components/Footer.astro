---
import services from '../data/services.json';

const currentYear = new Date().getFullYear();
const leistungen = services.map((s) => ({ href: `/leistungen/${s.slug}`, label: s.title }));

const IconPhone = () => `
<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
</svg>`;

const IconMail = () => `
<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l9 6 9-6"/>
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 8v10a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h14a2 2 0 012 2z"/>
</svg>`;

const IconMap = () => `
<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21s7-5.5 7-11a7 7 0 10-14 0c0 5.5 7 11 7 11z"/>
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10a2 2 0 100-4 2 2 0 000 4z"/>
</svg>`;

const IconFacebook = () => `
<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
  <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06C2 17.08 5.66 21.23 10.44 22v-7.03H7.9v-2.91h2.54V9.85c0-2.52 1.49-3.9 3.77-3.9 1.09 0 2.23.2 2.23.2v2.47h-1.25c-1.23 0-1.61.77-1.61 1.56v1.87h2.74l-.44 2.91h-2.3V22C18.34 21.23 22 17.08 22 12.06z"/>
</svg>`;
---

<footer class="bg-primary text-white pt-16 pb-8">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-12">
      <!-- Logo & About -->
      <div class="md:col-span-1">
        <div class="mb-4">
          <span class="text-xl font-bold tracking-tight">KANZLEI KARSTEN WALZ</span>
          <div class="text-xs text-white/60 tracking-widest uppercase">Steuerberater</div>
        </div>
        <p class="text-white/70 text-sm">
          Ihr verlässlicher Partner für alle steuerlichen Angelegenheiten seit 2000.
        </p>

        <div class="mt-6 flex items-center gap-3">
          <a
            href="#"
            class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-secondary/35 bg-white/10 text-white/90 hover:bg-white/15 hover:text-white transition-all duration-300 hover:scale-105"
            aria-label="Facebook"
          >
            <span set:html={IconFacebook()} />
          </a>
        </div>
      </div>

      <!-- Leistungen -->
      <div>
        <h3 class="font-semibold mb-4">
          Leistungen
          <div class="w-10 h-0.5 bg-secondary/80 mt-2"></div>
        </h3>
        <ul class="space-y-2">
          {leistungen.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-white transition-colors duration-300 text-sm a-underline">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="font-semibold mb-4">
          Kontakt
          <div class="w-10 h-0.5 bg-secondary/80 mt-2"></div>
        </h3>
        <ul class="space-y-3 text-white/70 text-sm">
          <li class="flex items-start gap-2">
            <span class="text-secondary mt-0.5" set:html={IconMap()} />
            <span>
              Ziegenhainer Str. 3<br />
              34613 Schwalmstadt
            </span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-secondary" set:html={IconPhone()} />
            <a href="tel:066914271" class="hover:text-white transition-colors duration-300">06691 4271</a>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-secondary" set:html={IconMail()} />
            <a href="mailto:info@kanzlei-karstenwalz.de" class="hover:text-white transition-colors duration-300">
              info@kanzlei-karstenwalz.de
            </a>
          </li>
        </ul>

        <div class="mt-6">
          <div class="text-white font-semibold mb-2">Öffnungszeiten</div>
          <div class="text-white/70 text-sm space-y-1">
            <div class="flex items-center justify-between gap-6"><span>Mo – Do</span><span>08:00 – 12:30 · 13:30 – 17:00</span></div>
            <div class="flex items-center justify-between gap-6"><span>Fr</span><span>08:00 – 13:00</span></div>
          </div>
        </div>
      </div>

      <!-- Rechtliches -->
      <div>
        <h3 class="font-semibold mb-4">
          Rechtliches
          <div class="w-10 h-0.5 bg-secondary/80 mt-2"></div>
        </h3>
        <ul class="space-y-2">
          <li>
            <a href="/impressum" class="text-white/70 hover:text-white transition-colors duration-300 text-sm a-underline">
              Impressum
            </a>
          </li>
          <li>
            <a href="/datenschutz" class="text-white/70 hover:text-white transition-colors duration-300 text-sm a-underline">
              Datenschutz
            </a>
          </li>
          <li>
            <a href="/kontakt" class="text-white/70 hover:text-white transition-colors duration-300 text-sm a-underline">
              Kontakt
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-white/20 pt-8 text-center text-white/50 text-sm">
      <p>© {currentYear} Kanzlei Karsten Walz. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>
