---
const stats = [
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    value: 'Seit 2000',
    label: 'Ihre Kanzlei in der Region'
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
    value: '13+ Mitarbeiter',
    label: 'Ein starkes Team für Sie'
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>`,
    value: 'Persönliche Beratung',
    label: 'Immer ein offenes Ohr'
  }
];
---

<section class="py-20 md:py-24 bg-bg">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12">
      {stats.map(stat => (
        <div class="text-center">
          <div class="text-secondary mb-4 flex justify-center" set:html={stat.icon} />
          <div class="text-2xl md:text-3xl font-bold text-primary mb-2">{stat.value}</div>
          <div class="text-text-light">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
