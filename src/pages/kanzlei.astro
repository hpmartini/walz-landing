---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import ChatWidget from '../components/ChatWidget.astro';
---

<Layout title="Kanzlei" description="Kanzlei Karsten Walz – Steuerberater in Schwalmstadt. Persönlich, kompetent, zuverlässig.">
  <Header />

  <main>
    <PageHero title="Kanzlei" subtitle="Verlässliche Steuerberatung – mit Haltung, Struktur und regionaler Nähe." />

    <section class="py-16 md:py-20 bg-bg">
      <div class="max-w-[1000px] mx-auto px-6">
        <div class="reveal">
          <h2 class="text-2xl md:text-3xl font-bold text-primary">Wofür wir stehen</h2>
          <div class="w-16 h-1 bg-secondary mt-5 mb-8"></div>
          <p class="text-text-light text-lg">
            Wir verbinden klassische Steuerberatung mit modernen, effizienten Abläufen. Unser Ziel: weniger Reibung,
            klare Zahlen und eine Zusammenarbeit, die sich im Alltag gut anfühlt.
          </p>
        </div>

        <div class="mt-10 grid md:grid-cols-3 gap-6">
          {[{
            title: 'Persönlich',
            text: 'Direkte Ansprechpartner, kurze Wege und ein offenes Ohr – für Mandanten und Unternehmen in der Region.',
          },{
            title: 'Strukturiert',
            text: 'Saubere Prozesse, verlässliche Termine, transparente Kommunikation – damit Sie planen können.',
          },{
            title: 'Vorausschauend',
            text: 'Gestaltungsberatung statt nur Abgabe: Wir denken steuerliche Entscheidungen pragmatisch nach vorne.',
          }].map((c, idx) => (
            <div class="reveal bg-white rounded-2xl border border-secondary/15 shadow-sm p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300" style={`transition-delay:${idx * 70}ms`}>
              <div class="text-xs font-semibold text-secondary tracking-widest uppercase">Prinzip</div>
              <h3 class="text-xl font-bold text-primary mt-2">{c.title}</h3>
              <div class="w-12 h-0.5 bg-secondary/80 mt-3"></div>
              <p class="text-text-light mt-5">{c.text}</p>
            </div>
          ))}
        </div>

        <div class="mt-12 reveal">
          <div class="rounded-2xl overflow-hidden border border-secondary/20 shadow-sm">
            <img src="/images/team/header_Unterseite.jpg" alt="Kanzlei" class="w-full h-[320px] object-cover" loading="lazy" decoding="async" />
          </div>
        </div>

        <div class="mt-12 reveal">
          <a href="/kontakt" class="inline-flex items-center gap-2 bg-primary text-white px-7 py-3 rounded-lg font-semibold transition-all duration-300 hover:bg-primary-light hover:scale-105">
            Kontakt aufnehmen
            <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ChatWidget />
</Layout>
