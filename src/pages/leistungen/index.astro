---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import ChatWidget from '../../components/ChatWidget.astro';

import services from '../../data/services.json';
---

<Layout title="Leistungen" description="Leistungen der Kanzlei Karsten Walz – Steuerberatung, Buchhaltung, Jahresabschlüsse, Lohnbuchhaltung und mehr.">
  <Header />

  <main>
    <PageHero
      title="Leistungen"
      subtitle="Ganzheitliche steuerliche und betriebswirtschaftliche Betreuung – klar, zuverlässig und persönlich."
    />

    <section class="py-16 md:py-20 bg-bg">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid lg:grid-cols-3 gap-10 items-start">
          <div class="lg:col-span-1 reveal">
            <h2 class="text-2xl md:text-3xl font-bold text-primary">Wobei wir Sie unterstützen</h2>
            <div class="w-16 h-1 bg-secondary mt-5"></div>
            <p class="text-text-light mt-6">
              Ob Sie gründen, wachsen oder Ihre Prozesse vereinfachen möchten: Wir übernehmen die steuerliche Arbeit
              und geben Ihnen die Sicherheit, die Sie für Entscheidungen brauchen.
            </p>
            <div class="mt-8">
              <a href="/kontakt" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 hover:bg-primary-light hover:scale-105">
                Beratung anfragen
                <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>

          <div class="lg:col-span-2">
            <div class="grid sm:grid-cols-2 gap-6">
              {services.map((s, idx) => (
                <a
                  href={`/leistungen/${s.slug}`}
                  class="reveal bg-white rounded-2xl p-8 border border-secondary/15 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                  style={`transition-delay:${Math.min(idx * 60, 240)}ms`}
                >
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-xl font-semibold text-primary">
                        {s.title}
                      </h3>
                      <div class="w-12 h-0.5 bg-secondary/80 mt-3"></div>
                    </div>
                    <span class="w-11 h-11 rounded-xl border border-secondary/25 bg-secondary/10 inline-flex items-center justify-center">
                      <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </div>

                  <p class="text-text-light mt-5">{s.shortDesc}</p>

                  <div class="mt-6 text-primary font-medium inline-flex items-center gap-2">
                    Details ansehen
                    <span class="h-px w-10 bg-secondary/70"></span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ChatWidget />
</Layout>
